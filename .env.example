# Railway Variables (Settings → Variables)
# Postgres eklentisi eklediğinizde DATABASE_URL otomatik gelir.

DATABASE_URL=postgresql://user:password@host:5432/railway
PORT=8080
NODE_ENV=production
BASE_PATH=/

# WhatsApp oturum dosyaları (Railway Volume mount önerilir)
# Volume path örneği: /data  →  WHATSAPP_AUTH_DIR=/data/whatsapp-auth
WHATSAPP_AUTH_DIR=./artifacts/api-server/whatsapp-auth
